<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RogueEngine.Editor.ViewModels"
        xmlns:views="using:RogueEngine.Editor.Views"
        xmlns:controls="using:RogueEngine.Editor.Controls"
        x:Class="RogueEngine.Editor.Views.EditorShellWindow"
        x:DataType="vm:EditorShellViewModel"
        Title="{Binding WindowTitle}"
        Width="1280"
        Height="820"
        MinWidth="1100"
        MinHeight="700"
        Background="#111114"
        Foreground="#e3e3e6">

  <DockPanel>
    <Border DockPanel.Dock="Top" Background="#16161a" BorderBrush="#2d2d35" BorderThickness="0,0,0,1" Padding="10,6">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
          <Button Content="Projects" Command="{Binding ReturnToLauncherCommand}" ToolTip.Tip="Back to project hub" />
          <Separator Width="1" Height="18" Background="#2d2d35" Margin="4,0" />
          <Button Content="Save" Command="{Binding SaveProjectCommand}" />
          <Button Content="Validate" Command="{Binding ValidateProjectCommand}" />
          <Button Classes="playtest" Content="Run" Command="{Binding PlaytestCommand}" IsEnabled="{Binding !IsPlaytestRunning}" />
          <Button Classes="stop" Content="Stop" Command="{Binding StopPlaytestCommand}" IsEnabled="{Binding IsPlaytestRunning}" />
          <Button Classes="build" Content="Build" Command="{Binding BuildProjectCommand}" />
        </StackPanel>
        <TextBlock Grid.Column="2" Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="#9a9a9f" />
      </Grid>
    </Border>

    <Border DockPanel.Dock="Bottom" Height="140" Background="#0c0c0f" BorderBrush="#2d2d35" BorderThickness="0,1,0,0" Padding="10">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Output" FontSize="11" Foreground="#9a9a9f" Margin="0,0,0,4" />
        <TextBox Text="{Binding OutputText}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                 FontFamily="Consolas, Cascadia Code, Courier New, monospace" Background="#0c0c0f" Foreground="#d1d1d6" BorderThickness="0" FontSize="11" />
      </DockPanel>
    </Border>

    <Grid ColumnDefinitions="250,*,260">
      <Border Grid.Column="0" Background="#16161a" BorderBrush="#2d2d35" BorderThickness="0,0,1,0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Resources" FontSize="11" Foreground="#9a9a9f" Margin="10,10,10,6" />
          <TreeView x:Name="ResourceTreeView" ItemsSource="{Binding ResourceTree}" DoubleTapped="OnResourceDoubleTapped" SelectionChanged="OnResourceSelectionChanged" Margin="4">
            <TreeView.ItemTemplate>
              <TreeDataTemplate ItemsSource="{Binding Children}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="{Binding Icon}" Foreground="#7a7a80" FontFamily="Consolas, monospace" FontSize="11" />
                  <TextBlock Text="{Binding Title}" />
                </StackPanel>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </DockPanel>
      </Border>

      <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="6,6,6,6">
        <Border Grid.Row="0" Background="#16161a" BorderBrush="#2d2d35" BorderThickness="1,1,1,0">
          <ListBox ItemsSource="{Binding OpenDocuments}" SelectedItem="{Binding SelectedDocument}" Background="Transparent" BorderThickness="0">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="2,0">
                  <Button Classes="doc-tab" Command="{Binding $parent[Window].((vm:EditorShellViewModel)DataContext).SelectDocumentCommand}" CommandParameter="{Binding}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding Icon}" FontFamily="Consolas, monospace" FontSize="11" Foreground="#7a7a80" />
                      <TextBlock Text="{Binding Title}" />
                      <TextBlock Text="*" IsVisible="{Binding IsModified}" Foreground="#c9a227" FontSize="10" VerticalAlignment="Center" />
                    </StackPanel>
                  </Button>
                  <Button Classes="doc-tab-close" Content="×" Command="{Binding $parent[Window].((vm:EditorShellViewModel)DataContext).CloseDocumentCommand}" CommandParameter="{Binding}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>

        <Border Grid.Row="1" Background="#1c1c21" BorderBrush="#2d2d35" BorderThickness="1,0,1,1" Padding="12">
          <Grid>
            <StackPanel IsVisible="{Binding IsWelcomeDocument}" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
              <TextBlock Text="Select a resource" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
              <TextBlock Text="Double-click scenes, actors, scripts, or visual scripts to open them. Use Run to playtest." Foreground="#9a9a9f" TextWrapping="Wrap" TextAlignment="Center" />
            </StackPanel>

            <ScrollViewer IsVisible="{Binding IsSettingsDocument}">
              <StackPanel Spacing="10">
                <TextBlock Text="Project settings" FontSize="18" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="140,*">
                  <TextBlock Grid.Column="0" Text="Name" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding ProjectName}" />
                </Grid>
                <Grid ColumnDefinitions="140,*">
                  <TextBlock Grid.Column="0" Text="Map width" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1" Minimum="10" Maximum="200" Value="{Binding MapWidth}" />
                </Grid>
                <Grid ColumnDefinitions="140,*">
                  <TextBlock Grid.Column="0" Text="Map height" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1" Minimum="10" Maximum="100" Value="{Binding MapHeight}" />
                </Grid>
                <Grid ColumnDefinitions="140,*">
                  <TextBlock Grid.Column="0" Text="Message panel" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1" Minimum="1" Maximum="20" Value="{Binding MessagePanelHeight}" />
                </Grid>
                <Grid ColumnDefinitions="140,*">
                  <TextBlock Grid.Column="0" Text="Min enemies" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1" Minimum="0" Maximum="50" Value="{Binding MinEnemies}" />
                </Grid>
                <Grid ColumnDefinitions="140,*">
                  <TextBlock Grid.Column="0" Text="Max enemies" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1" Minimum="0" Maximum="50" Value="{Binding MaxEnemies}" />
                </Grid>
              </StackPanel>
            </ScrollViewer>

            <Grid IsVisible="{Binding IsSceneDocument}" RowDefinitions="Auto,*">
              <StackPanel Grid.Row="0" Spacing="8">
                <TextBlock Text="Scene" FontSize="18" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="120,*,120,*">
                  <TextBlock Grid.Column="0" Text="ID" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding SceneId}" />
                  <TextBlock Grid.Column="2" Text="Name" VerticalAlignment="Center" Margin="10,0,0,0" />
                  <TextBox Grid.Column="3" Text="{Binding SceneName}" />
                </Grid>
                <Grid ColumnDefinitions="120,*,80,*,80,*">
                  <TextBlock Grid.Column="0" Text="Generator" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding SceneGenerator}" Watermark="generators/dungeon.json" />
                  <TextBlock Grid.Column="2" Text="W" VerticalAlignment="Center" Margin="10,0,0,0" />
                  <NumericUpDown Grid.Column="3" Minimum="10" Maximum="200" Value="{Binding SceneWidth}" />
                  <TextBlock Grid.Column="4" Text="H" VerticalAlignment="Center" Margin="10,0,0,0" />
                  <NumericUpDown Grid.Column="5" Minimum="10" Maximum="100" Value="{Binding SceneHeight}" />
                </Grid>
                <TextBlock Text="Shift+click sets player spawn. Actor combo places enemies; item combo places pickups." FontSize="11" Foreground="#9a9a9f" />
              </StackPanel>
              <controls:SceneMapViewport x:Name="SceneViewport" Grid.Row="1" Margin="0,8,0,0"
                                         Scene="{Binding SelectedScene}"
                                         Actors="{Binding Actors}"
                                         Items="{Binding Items}"
                                         Map="{Binding ScenePreviewMap}" />
            </Grid>

            <ScrollViewer IsVisible="{Binding IsActorDocument}">
              <StackPanel Spacing="10">
                <TextBlock Text="Actor" FontSize="18" FontWeight="SemiBold" />
                <Border Width="56" Height="56" Background="#232329" HorizontalAlignment="Left">
                  <TextBlock Text="{Binding ActorGlyph}" FontSize="28" FontWeight="Bold" Foreground="#5b8def" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="ID" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding ActorId}" />
                </Grid>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="Glyph" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding ActorGlyph}" MaxLength="1" />
                </Grid>
                <Grid ColumnDefinitions="120,*,*,*">
                  <TextBlock Grid.Column="0" Text="RGB" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ActorColorR}" />
                  <NumericUpDown Grid.Column="2" Minimum="0" Maximum="255" Value="{Binding ActorColorG}" Margin="4,0" />
                  <NumericUpDown Grid.Column="3" Minimum="0" Maximum="255" Value="{Binding ActorColorB}" />
                </Grid>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="Max HP" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1" Minimum="1" Maximum="999" Value="{Binding ActorMaxHp}" />
                </Grid>
                <CheckBox Content="Is player" IsChecked="{Binding ActorIsPlayer}" />
                <CheckBox Content="Blocks movement" IsChecked="{Binding ActorBlocksMovement}" />
                <CheckBox Content="Chase AI" IsChecked="{Binding ActorHasChaseAI}" />
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="Behavior" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding ActorBehavior}" />
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button Content="Add actor" Command="{Binding AddActorCommand}" />
                  <Button Content="Remove" Command="{Binding RemoveActorCommand}" />
                </StackPanel>
              </StackPanel>
            </ScrollViewer>

            <ScrollViewer IsVisible="{Binding IsGeneratorDocument}">
              <StackPanel Spacing="10">
                <TextBlock Text="Map generator" FontSize="18" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="ID" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding GeneratorId}" />
                </Grid>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="Algorithm" VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1" ItemsSource="{Binding GeneratorAlgorithms}" SelectedItem="{Binding GeneratorAlgorithm}" />
                </Grid>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="Width" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1" Minimum="10" Maximum="200" Value="{Binding GeneratorWidth}" />
                </Grid>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="Height" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1" Minimum="10" Maximum="100" Value="{Binding GeneratorHeight}" />
                </Grid>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="Seed" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding GeneratorSeedText}" Watermark="Random if empty" />
                </Grid>
                <Expander Header="Algorithm parameters" IsExpanded="True">
                  <StackPanel Spacing="8" Margin="0,8,0,0">
                    <Grid ColumnDefinitions="120,*">
                      <TextBlock Grid.Column="0" Text="Tileset path" VerticalAlignment="Center" />
                      <TextBox Grid.Column="1" Text="{Binding GenTilesetPath}" Watermark="tilesets/stone_walls.json" />
                    </Grid>
                    <Grid ColumnDefinitions="120,*,120,*">
                      <TextBlock Grid.Column="0" Text="Fill %" VerticalAlignment="Center" />
                      <NumericUpDown Grid.Column="1" Minimum="10" Maximum="90" Value="{Binding GenFillPercent}" />
                      <TextBlock Grid.Column="2" Text="Smooth" VerticalAlignment="Center" Margin="10,0,0,0" />
                      <NumericUpDown Grid.Column="3" Minimum="1" Maximum="20" Value="{Binding GenSmoothPasses}" />
                    </Grid>
                    <Grid ColumnDefinitions="120,*,120,*">
                      <TextBlock Grid.Column="0" Text="Wall thresh" VerticalAlignment="Center" />
                      <NumericUpDown Grid.Column="1" Minimum="1" Maximum="8" Value="{Binding GenWallThreshold}" />
                      <TextBlock Grid.Column="2" Text="Floor target" VerticalAlignment="Center" Margin="10,0,0,0" />
                      <NumericUpDown Grid.Column="3" Minimum="100" Maximum="5000" Value="{Binding GenTargetFloorCount}" />
                    </Grid>
                    <Grid ColumnDefinitions="120,*,120,*">
                      <TextBlock Grid.Column="0" Text="Walkers" VerticalAlignment="Center" />
                      <NumericUpDown Grid.Column="1" Minimum="1" Maximum="20" Value="{Binding GenWalkerCount}" />
                      <TextBlock Grid.Column="2" Text="Split depth" VerticalAlignment="Center" Margin="10,0,0,0" />
                      <NumericUpDown Grid.Column="3" Minimum="1" Maximum="10" Value="{Binding GenSplitDepth}" />
                    </Grid>
                    <Grid ColumnDefinitions="120,*,120,*">
                      <TextBlock Grid.Column="0" Text="Min room" VerticalAlignment="Center" />
                      <NumericUpDown Grid.Column="1" Minimum="3" Maximum="20" Value="{Binding GenMinRoomSize}" />
                      <TextBlock Grid.Column="2" Text="Max room" VerticalAlignment="Center" Margin="10,0,0,0" />
                      <NumericUpDown Grid.Column="3" Minimum="4" Maximum="30" Value="{Binding GenMaxRoomSize}" />
                    </Grid>
                  </StackPanel>
                </Expander>
              </StackPanel>
            </ScrollViewer>

            <ScrollViewer IsVisible="{Binding IsItemDocument}">
              <StackPanel Spacing="10">
                <TextBlock Text="Item" FontSize="18" FontWeight="SemiBold" />
                <Border Width="56" Height="56" Background="#232329" HorizontalAlignment="Left">
                  <TextBlock Text="{Binding ItemGlyph}" FontSize="28" FontWeight="Bold" Foreground="#c94f4f" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="ID" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding ItemId}" />
                </Grid>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="Name" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding ItemName}" />
                </Grid>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="Glyph" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding ItemGlyph}" MaxLength="1" />
                </Grid>
                <Grid ColumnDefinitions="120,*,*,*">
                  <TextBlock Grid.Column="0" Text="RGB" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ItemColorR}" />
                  <NumericUpDown Grid.Column="2" Minimum="0" Maximum="255" Value="{Binding ItemColorG}" Margin="4,0" />
                  <NumericUpDown Grid.Column="3" Minimum="0" Maximum="255" Value="{Binding ItemColorB}" />
                </Grid>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="Kind" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding ItemKind}" Watermark="consumable / equipment / key" />
                </Grid>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="Max stack" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1" Minimum="1" Maximum="99" Value="{Binding ItemMaxStack}" />
                </Grid>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="Equip slot" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding ItemEquipSlot}" Watermark="weapon / armor" />
                </Grid>
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="Heal on use" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1" Minimum="0" Maximum="999" Value="{Binding ItemHealOnUse}" />
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button Content="Add item" Command="{Binding AddItemCommand}" />
                  <Button Content="Remove" Command="{Binding RemoveItemCommand}" />
                </StackPanel>
              </StackPanel>
            </ScrollViewer>

            <ScrollViewer IsVisible="{Binding IsOverworldDocument}">
              <StackPanel Spacing="10">
                <TextBlock Text="Overworld" FontSize="18" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="120,*">
                  <TextBlock Grid.Column="0" Text="ID" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding OverworldId}" />
                </Grid>
                <TextBlock Text="Cells" FontWeight="SemiBold" />
                <ListBox ItemsSource="{Binding OverworldCells}" Height="180">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock>
                        <Run Text="{Binding Id}" />
                        <Run Text=" @ " Foreground="#9a9a9f" />
                        <Run Text="{Binding X}" />
                        <Run Text="," />
                        <Run Text="{Binding Y}" />
                        <Run Text=" — " Foreground="#9a9a9f" />
                        <Run Text="{Binding LocalGenerator}" />
                      </TextBlock>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <Button Content="Add cell" Command="{Binding AddOverworldCellCommand}" HorizontalAlignment="Left" />
                <TextBlock Text="Connections" FontWeight="SemiBold" Margin="0,8,0,0" />
                <ListBox ItemsSource="{Binding OverworldConnections}" Height="120">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock>
                        <Run Text="{Binding From}" />
                        <Run Text=" → " Foreground="#9a9a9f" />
                        <Run Text="{Binding To}" />
                        <Run Text=" (" Foreground="#9a9a9f" />
                        <Run Text="{Binding Type}" />
                        <Run Text=")" Foreground="#9a9a9f" />
                      </TextBlock>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <Button Content="Add connection" Command="{Binding AddOverworldConnectionCommand}" HorizontalAlignment="Left" />
              </StackPanel>
            </ScrollViewer>

            <Grid IsVisible="{Binding IsVisualScriptDocument}" ColumnDefinitions="220,*">
              <DockPanel Grid.Column="0" Margin="0,0,10,0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                  <Button Content="Add node" Command="{Binding AddVisualNodeCommand}" />
                  <Button Content="Remove" Command="{Binding RemoveVisualNodeCommand}" />
                </StackPanel>
                <Button DockPanel.Dock="Bottom" Content="Preview C#" Command="{Binding PreviewVisualScriptCommand}" Margin="0,6,0,0" />
                <ListBox ItemsSource="{Binding VisualNodes}" SelectedItem="{Binding SelectedVisualNode}" />
              </DockPanel>
              <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="100,*">
                    <TextBlock Grid.Column="0" Text="Graph ID" />
                    <TextBox Grid.Column="1" Text="{Binding VisualGraphId}" />
                  </Grid>
                  <Grid ColumnDefinitions="100,*">
                    <TextBlock Grid.Column="0" Text="Entry" />
                    <TextBox Grid.Column="1" Text="{Binding VisualGraphEntryNodeId}" />
                  </Grid>
                  <Grid ColumnDefinitions="100,*">
                    <TextBlock Grid.Column="0" Text="Node ID" />
                    <TextBox Grid.Column="1" Text="{Binding VisualNodeId}" />
                  </Grid>
                  <Grid ColumnDefinitions="100,*">
                    <TextBlock Grid.Column="0" Text="Type" />
                    <ComboBox Grid.Column="1" ItemsSource="{Binding VisualNodeTypes}" SelectedItem="{Binding VisualNodeType}" />
                  </Grid>
                  <Grid ColumnDefinitions="100,*">
                    <TextBlock Grid.Column="0" Text="Next" />
                    <TextBox Grid.Column="1" Text="{Binding VisualNodeNext}" />
                  </Grid>
                  <Grid ColumnDefinitions="100,*">
                    <TextBlock Grid.Column="0" Text="True" />
                    <TextBox Grid.Column="1" Text="{Binding VisualNodeTrueBranch}" />
                  </Grid>
                  <Grid ColumnDefinitions="100,*">
                    <TextBlock Grid.Column="0" Text="False" />
                    <TextBox Grid.Column="1" Text="{Binding VisualNodeFalseBranch}" />
                  </Grid>
                  <Grid ColumnDefinitions="100,*">
                    <TextBlock Grid.Column="0" Text="Message" />
                    <TextBox Grid.Column="1" Text="{Binding VisualNodeMessage}" />
                  </Grid>
                  <Border Background="#0c0c0f" BorderBrush="#2d2d35" BorderThickness="1" Padding="8" MinHeight="120">
                    <TextBox Text="{Binding VisualScriptPreview}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             FontFamily="Consolas, monospace" Background="Transparent" BorderThickness="0" Foreground="#9ab4f0" FontSize="11" />
                  </Border>
                </StackPanel>
              </ScrollViewer>
            </Grid>

            <DockPanel IsVisible="{Binding IsCodeScriptDocument}">
              <TextBlock DockPanel.Dock="Top" Text="{Binding CodeScriptFileName}" FontWeight="SemiBold" Margin="0,0,0,6" />
              <TextBox Text="{Binding CodeScriptContent}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                       FontFamily="Consolas, monospace" FontSize="12" />
            </DockPanel>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Column="2" Background="#16161a" BorderBrush="#2d2d35" BorderThickness="1,0,0,0" Padding="10">
        <views:InspectorPanel DataContext="{Binding}" />
      </Border>
    </Grid>
  </DockPanel>
</Window>
