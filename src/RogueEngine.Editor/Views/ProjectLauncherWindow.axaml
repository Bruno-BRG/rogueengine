<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RogueEngine.Editor.ViewModels"
        x:Class="RogueEngine.Editor.Views.ProjectLauncherWindow"
        x:DataType="vm:ProjectLauncherViewModel"
        Title="RogueEngine"
        Width="960"
        Height="640"
        MinWidth="800"
        MinHeight="560"
        Background="#111114"
        Foreground="#e3e3e6"
        WindowStartupLocation="CenterScreen">

  <Grid ColumnDefinitions="*,340">
    <Border Grid.Column="0" Padding="40">
      <StackPanel VerticalAlignment="Center" Spacing="20" MaxWidth="460">
        <StackPanel Spacing="6">
          <TextBlock Text="RogueEngine" FontSize="36" FontWeight="SemiBold" Foreground="#ffffff" />
          <TextBlock Text="Open or create a project" FontSize="14" Foreground="#9a9a9f" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Classes="primary" Content="New project" Command="{Binding CreateProjectCommand}" />
          <Button Content="Open project" Command="{Binding OpenProjectCommand}" />
        </StackPanel>

        <Border IsVisible="{Binding MostRecentProject, Converter={x:Static ObjectConverters.IsNotNull}}"
                Background="#1c1c21" BorderBrush="#2d2d35" BorderThickness="1" Padding="14">
          <StackPanel Spacing="8">
            <TextBlock Text="Recent" FontSize="11" Foreground="#9a9a9f" />
            <TextBlock Text="{Binding MostRecentProject.Name}" FontSize="16" FontWeight="SemiBold" Foreground="#5b8def" />
            <TextBlock Text="{Binding MostRecentProject.ReprojPath}" FontSize="11" Foreground="#7a7a80" TextWrapping="Wrap" />
            <TextBlock FontSize="11" Foreground="#9a9a9f">
              <Run Text="Last opened " />
              <Run Text="{Binding MostRecentProject.LastOpenedDisplay}" />
            </TextBlock>
            <Button Classes="primary" Content="Open" Command="{Binding OpenMostRecentProjectCommand}" HorizontalAlignment="Left" />
          </StackPanel>
        </Border>

        <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#9a9a9f" />
      </StackPanel>
    </Border>

    <Border Grid.Column="1" Background="#16161a" BorderBrush="#2d2d35" BorderThickness="1,0,0,0" Padding="20">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Recent projects" FontSize="11" Foreground="#9a9a9f" Margin="0,0,0,10" />
        <Button DockPanel.Dock="Bottom" Content="Open selected" Command="{Binding OpenRecentProjectCommand}" HorizontalAlignment="Stretch" Margin="0,10,0,0" />

        <ListBox ItemsSource="{Binding RecentProjects}" SelectedItem="{Binding SelectedRecentProject}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding ReprojPath}" FontSize="10" Foreground="#7a7a80" TextWrapping="Wrap" />
                <TextBlock Text="{Binding LastOpenedDisplay}" FontSize="10" Foreground="#9a9a9f" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>
  </Grid>
</Window>
